#include <Arduino.h>

const int green = 3;
const int red = 6;
const int blue = 5;



void setup() {
  Serial.begin(9600);
  pinMode (green, OUTPUT);
  pinMode (red, OUTPUT);
  pinMode (blue, OUTPUT);

}

void loop() {
  Serial.print("Red");
  DigitalWrite(red, HIGH);
  DigitalWrite(blue, LOW);
  DigitalWrite(green, LOW);
  delay(1000);
  Serial.print("Green");
  DigitalWrite(red, LOW);
  DigitalWrite(blue, LOW);
  DigitalWrite(green, HIGH);
  delay(1000);
  Serial.print("Blue");
  DigitalWrite(red, LOW);
  DigitalWrite(blue, HIGH);
  DigitalWrite(green, LOW);
  delay(1000);          
}
